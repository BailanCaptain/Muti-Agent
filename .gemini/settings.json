{
  "mcpServers": {
    "multi_agent_room": {
      "command": "node",
      "args": [
        "packages/api/dist/mcp/server.js"
      ],
      "env": {
        "MULTI_AGENT_API_URL": "${MULTI_AGENT_API_URL}",
        "MULTI_AGENT_INVOCATION_ID": "${MULTI_AGENT_INVOCATION_ID}",
        "MULTI_AGENT_CALLBACK_TOKEN": "${MULTI_AGENT_CALLBACK_TOKEN}"
      }
    }
  }
}
