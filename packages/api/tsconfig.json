{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "noEmit": false,
    "lib": ["es2022"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@multi-agent/shared": ["../shared/dist/index.d.ts"],
      "@multi-agent/shared/*": ["../shared/dist/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["../../node_modules"]
}
