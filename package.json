{
  "name": "multi-agent",
  "version": "2.0.0",
  "private": true,
  "packageManager": "pnpm@10.6.1",
  "engines": {
    "node": ">=20.9"
  },
  "scripts": {
    "dev": "pnpm run dev:web",
    "dev:web": "next dev",
    "dev:api": "bash scripts/mount-skills.sh && tsc -p packages/shared/tsconfig.json && tsx watch packages/api/src/index.ts",
    "build": "tsc -p packages/shared/tsconfig.json && next build && tsc -p packages/api/tsconfig.json",
    "start": "next start",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit && pnpm --filter @multi-agent/shared typecheck && pnpm --filter @multi-agent/api typecheck",
    "check:skills": "npx tsx scripts/check-skills.ts"
  },
  "dependencies": {
    "@multi-agent/shared": "workspace:*",
    "@tanstack/react-virtual": "^3.13.23",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.0.10",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2"
  }
}
