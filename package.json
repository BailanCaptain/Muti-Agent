{
  "name": "multi-agent",
  "version": "2.0.0",
  "private": true,
  "packageManager": "pnpm@10.6.1",
  "engines": {
    "node": ">=20.9"
  },
  "scripts": {
    "dev": "pnpm run dev:web",
    "dev:web": "next dev --webpack",
    "dev:api": "tsc -p packages/shared/tsconfig.json && tsc -p packages/api/tsconfig.json && node packages/api/dist/index.js",
    "build": "tsc -p packages/shared/tsconfig.json && next build --webpack && tsc -p packages/api/tsconfig.json",
    "start": "next start",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit && pnpm --filter @multi-agent/shared typecheck && pnpm --filter @multi-agent/api typecheck"
  },
  "dependencies": {
    "@multi-agent/shared": "workspace:*",
    "clsx": "^2.1.1",
    "next": "16.0.10",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2"
  }
}
